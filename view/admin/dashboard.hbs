<div class="admin-page">
    <div class="admin-container">

        <!-- HEADER -->
        <div class="admin-header">
            <div class="admin-header-left">
                <i class='bx bx-shield-quarter admin-header-icon'></i>
                <div>
                    <h1 class="admin-title">Админ Панель</h1>
                    <p class="admin-subtitle">Управление и мониторинг системы</p>
                </div>
            </div>
            <div class="admin-header-right">
                <a href="/admin/stats" class="admin-stats-btn">
                    <i class='bx bx-bar-chart-alt-2'></i> Подробная статистика
                </a>
            </div>
        </div>

        <!-- STAT CARDS -->
        <div class="admin-cards">

            <div class="admin-card admin-card-blue">
                <div class="admin-card-icon">
                    <i class='bx bx-package'></i>
                </div>
                <div class="admin-card-info">
                    <span class="admin-card-number">{{totalObjects}}</span>
                    <span class="admin-card-label">Все товары</span>
                </div>
            </div>

            <div class="admin-card admin-card-green">
                <div class="admin-card-icon">
                    <i class='bx bx-check-circle'></i>
                </div>
                <div class="admin-card-info">
                    <span class="admin-card-number">{{soldCount}}</span>
                    <span class="admin-card-label">Арендовано</span>
                </div>
            </div>

            <div class="admin-card admin-card-orange">
                <div class="admin-card-icon">
                    <i class='bx bx-time-five'></i>
                </div>
                <div class="admin-card-info">
                    <span class="admin-card-number">{{unsoldCount}}</span>
                    <span class="admin-card-label">Не арендовано</span>
                </div>
            </div>

            <div class="admin-card admin-card-purple">
                <div class="admin-card-icon">
                    <i class='bx bx-group'></i>
                </div>
                <div class="admin-card-info">
                    <span class="admin-card-number">{{totalUsers}}</span>
                    <span class="admin-card-label">Пользователи</span>
                </div>
            </div>

        </div>

        <!-- PRICE SUMMARY -->
        <div class="admin-price-summary">
            <div class="admin-price-card">
                <i class='bx bx-wallet'></i>
                <div>
                    <p class="admin-price-label">Общая стоимость товаров</p>
                    <p class="admin-price-value">{{formatPrice allTotalPrice}} ₽</p>
                </div>
            </div>
            <div class="admin-price-card admin-price-card-green">
                <i class='bx bx-trending-up'></i>
                <div>
                    <p class="admin-price-label">Арендованные — стоимость</p>
                    <p class="admin-price-value">{{formatPrice soldTotalPrice}} ₽</p>
                </div>
            </div>
            <div class="admin-price-card admin-price-card-red">
                <i class='bx bx-trending-down'></i>
                <div>
                    <p class="admin-price-label">Не арендованные — стоимость</p>
                    <p class="admin-price-value">{{formatPrice unsoldTotalPrice}} ₽</p>
                </div>
            </div>
        </div>

        <!-- TABLES -->
        <div class="admin-tables">

            <!-- RECENT OBJECTS -->
            <div class="admin-table-box">
                <div class="admin-table-header">
                    <h2><i class='bx bx-cube'></i> Последние товары</h2>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Название</th>
                            <th>Цена</th>
                            <th>Владелец</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if recentObjects}}
                        {{#each recentObjects}}
                        <tr>
                            <td><span class="admin-badge">#{{this.id}}</span></td>
                            <td>{{this.name}}</td>
                            <td class="admin-price-cell">{{formatPrice this.price}} ₽</td>
                            <td>{{this.user.email}}</td>
                            <td>{{formatDate this.createdAt}}</td>
                        </tr>
                        {{/each}}
                        {{else}}
                        <tr><td colspan="5" class="admin-empty">Нет данных</td></tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>

            <!-- RECENT RENTALS -->
            <div class="admin-table-box">
                <div class="admin-table-header">
                    <h2><i class='bx bx-receipt'></i> Последние аренды</h2>
                </div>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Товар</th>
                            <th>Цена</th>
                            <th>Покупатель</th>
                            <th>Статус</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#if recentRentals}}
                        {{#each recentRentals}}
                        <tr>
                            <td><span class="admin-badge">#{{this.id}}</span></td>
                            <td>{{this.thing.name}}</td>
                            <td class="admin-price-cell">{{formatPrice this.thing.price}} ₽</td>
                            <td>{{this.user.email}}</td>
                            <td>
                                {{#if (eq this.status "active")}}
                                <span class="admin-status admin-status-active">Активный</span>
                                {{else}}
                                <span class="admin-status admin-status-cancelled">Отменён</span>
                                {{/if}}
                            </td>
                            <td>{{formatDate this.createdAt}}</td>
                        </tr>
                        {{/each}}
                        {{else}}
                        <tr><td colspan="6" class="admin-empty">Нет данных</td></tr>
                        {{/if}}
                    </tbody>
                </table>
            </div>

        </div>

    </div>
</div>
